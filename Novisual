-- Desync & Fake Death Logic
local isGhostModeActive = false
local savedJoints = {}
local rootJointData = nil

fakeDeathBtn.MouseButton1Click:Connect(function()
    local character = localPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local lowerTorso = character:FindFirstChild("LowerTorso")
    
    if not humanoid or not rootPart or not lowerTorso then return end

    if not isGhostModeActive then
        -- Enable True Desync Ghost Mode
        isGhostModeActive = true
        fakeDeathBtn.Text = "desativar morte"
        fakeDeathBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)

        -- Prevent actual respawn when dismantled
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)

        -- Sever the Root joint first to freeze position for the server
        local rootJoint = lowerTorso:FindFirstChild("Root")
        if rootJoint then
            rootJointData = {
                Parent = rootJoint.Parent,
                Part0 = rootJoint.Part0,
                Part1 = rootJoint.Part1,
                C0 = rootJoint.C0,
                C1 = rootJoint.C1
            }
            rootJoint:Destroy()
        end

        -- Dismantle the rest of the body so it looks like a real death
        for _, obj in pairs(character:GetDescendants()) do
            if obj:IsA("Motor6D") and obj.Name ~= "Neck" and obj.Name ~= "Root" then
                table.insert(savedJoints, {
                    JointName = obj.Name,
                    Parent = obj.Parent,
                    Part0 = obj.Part0,
                    Part1 = obj.Part1,
                    C0 = obj.C0,
                    C1 = obj.C1
                })
                obj:Destroy()
            end
            
            -- Ensure collision is true so parts fall on the floor and stay there
            if obj:IsA("BasePart") and obj.Name ~= "HumanoidRootPart" then
                obj.CanCollide = true
            end
        end
        
        -- Lock camera to your moving invisible RootPart
        workspace.CurrentCamera.CameraSubject = rootPart
        
    else
        -- Disable Ghost Mode & Reassemble
        isGhostModeActive = false
        fakeDeathBtn.Text = "morte falsa r15"
        fakeDeathBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)

        -- Restore Root joint to sync back to the server
        if rootJointData then
            local newRoot = Instance.new("Motor6D")
            newRoot.Name = "Root"
            newRoot.Part0 = rootJointData.Part0
            newRoot.Part1 = rootJointData.Part1
            newRoot.C0 = rootJointData.C0
            newRoot.C1 = rootJointData.C1
            newRoot.Parent = rootJointData.Parent
            rootJointData = nil
        end

        -- Restore all other joints
        for _, jointData in pairs(savedJoints) do
            local newJoint = Instance.new("Motor6D")
            newJoint.Name = jointData.JointName
            newJoint.Part0 = jointData.Part0
            newJoint.Part1 = jointData.Part1
            newJoint.C0 = jointData.C0
            newJoint.C1 = jointData.C1
            newJoint.Parent = jointData.Parent
        end
        table.clear(savedJoints)

        -- Re-enable normal death
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
        
        -- Reset camera to Humanoid
        workspace.CurrentCamera.CameraSubject = humanoid
    end
end)
